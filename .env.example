# ── LLM Provider ──
# Options: anthropic, gemini, ollama
# Auto-detected from API keys if not set
LLM_PROVIDER=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Ollama (if LLM_PROVIDER=ollama)
# OLLAMA_MODEL=llama3
# OLLAMA_URL=http://localhost:11434

# ── Transcription Provider ──
# Options: groq, assemblyai (auto-detected from API keys if not set)
TRANSCRIPTION_PROVIDER=

PORT=3000

# ── Admin Auth ──
ADMIN_TOKEN=                        # Auto-generated if empty
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# ── Guest Access (optional) ──
GUEST_USERNAME=Guest
GUEST_PASSWORD=
GUEST_TOKEN=                        # Auto-generated if empty

# ── WhatsApp Config ──
# Comma-separated private chat names to monitor for events (in addition to groups)
ALLOWED_PRIVATE_CHATS=

# ── Relationship App (optional — leave empty to disable voice features) ──
GROQ_API_KEY=
ASSEMBLYAI_API_KEY=
RELATIONSHIP_CHAT_NAME=             # WhatsApp contact name to monitor
RELATIONSHIP_PARTNER_NAME=partner   # Label for the other person in transcripts

# ── Metacrisis App (optional) ──
METACRISIS_CHAT_NAME=
METACRISIS_ANNOUNCEMENT_CHAT=
METACRISIS_ADJACENT_EVENTS_CHAT=
# JSON map of WhatsApp IDs to display names, e.g. {"id@lid":"Name"}
SENDER_NAME_OVERRIDES={}

# ── Airtable Sync (optional) ──
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_ID=

# ── Scheduler ──
ANALYSIS_HOUR=0                     # Hour (0-23) for daily analysis (server local time)

# ── Storage Paths ──
# DB_PATH=./events.db
# AUTH_DIR=./.auth
